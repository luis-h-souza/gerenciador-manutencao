# ============================================================
# GERENCIADOR DE MANUTENÇÃO - Environment Variables
# ============================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3001
APP_NAME="Gerenciador de Manutenção"

# --- Banco de Dados (PostgreSQL) ---
DATABASE_URL="postgresql://manutencao_server:manutencao_password@localhost:5433/sgm_db?schema=public"

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Sessions (Express Session) ---
SESSION_SECRET=your_session_secret_key_change_in_production_min_32_chars
SESSION_MAX_AGE=86400000  # 24 horas em ms

# --- Redis (para sessions e rate limiting distribuído) ---
REDIS_URL=redis://localhost:6379
# Para Redis com senha:
# REDIS_URL=redis://:password@localhost:6379

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=100             # requisições por janela
AUTH_RATE_LIMIT_MAX=10         # tentativas de login por janela

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Logs ---
LOG_LEVEL=info
LOG_DIR=./logs
