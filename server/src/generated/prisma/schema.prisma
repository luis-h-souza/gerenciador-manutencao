generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Loja {
  id           String    @id @default(uuid())
  numero       Int       @unique
  nome         String
  regiao       String
  telefone     String?
  endereco     String?
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  usuarios     Usuario[]

  @@map("lojas")
}

model Usuario {
  id                    String                 @id @default(uuid())
  nome                  String
  email                 String                 @unique
  senha                 String
  role                  Role                   @default(TECNICO)
  ativo                 Boolean                @default(true)
  regiao                String?
  lojaId                String?
  criadoEm              DateTime               @default(now())
  atualizadoEm          DateTime               @updatedAt
  loja                  Loja?                  @relation(fields: [lojaId], references: [id])
  checklistsCarrinho    ChecklistCarrinho[]
  checklistsEquipamento ChecklistEquipamento[]
  notificacoes          Notificacao[]
  refreshTokens         RefreshToken[]
  sessoes               Sessao[]
  tarefasAtribuidas     Tarefa[]               @relation("TarefaAtribuida")
  tarefasCriadas        Tarefa[]               @relation("TarefaCriada")

  @@map("usuarios")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  usuarioId String
  expiresAt DateTime
  revogado  Boolean  @default(false)
  criadoEm  DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Sessao {
  id        String   @id @default(uuid())
  sessionId String   @unique
  usuarioId String
  ipAddress String?
  userAgent String?
  ativo     Boolean  @default(true)
  expiresAt DateTime
  criadoEm  DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

model Tarefa {
  id              String           @id @default(uuid())
  descricao       String
  prioridade      PrioridadeTarefa @default(MEDIA)
  status          StatusTarefa     @default(PENDENTE)
  areResponsavel  String
  regiao          String?
  unidade         String?
  dataConclusao   DateTime?
  criadoPorId     String
  atribuidoParaId String?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
  notificacoes    Notificacao[]
  atribuidoPara   Usuario?         @relation("TarefaAtribuida", fields: [atribuidoParaId], references: [id])
  criadoPor       Usuario          @relation("TarefaCriada", fields: [criadoPorId], references: [id])

  @@map("tarefas")
}

model Notificacao {
  id        String   @id @default(uuid())
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  tarefaId  String?
  usuarioId String?
  criadoEm  DateTime @default(now())
  tarefa    Tarefa?  @relation(fields: [tarefaId], references: [id])
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("notificacoes")
}

model ControleChamado {
  id              String          @id @default(uuid())
  dataAbertura    DateTime
  numeroChamado   String
  segmento        SegmentoChamado
  empresa         String
  descricao       String
  regiao          String?
  unidade         String?
  numeroOrcamento String?
  valor           Decimal?        @db.Decimal(12, 2)
  status          StatusChamado   @default(CHAMADO_ABERTO)
  mauUso          Boolean         @default(false)
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  @@map("controle_chamados")
}

model Fornecedor {
  id           String   @id @default(uuid())
  nome         String
  telefone     String?
  email        String?
  segmento     String
  cnpj         String   @unique
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("fornecedores")
}

model Peca {
  id                String             @id @default(uuid())
  nome              String
  descricao         String?
  quantidadeEstoque Int                @default(0)
  criadoEm          DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt
  entradas          EntradaPeca[]
  movimentacoes     MovimentacaoPeca[]
  saidas            SaidaPeca[]

  @@map("pecas")
}

model EntradaPeca {
  id               String   @id @default(uuid())
  pecaId           String
  dataEntrada      DateTime
  quantidade       Int
  valorUnitario    Decimal  @db.Decimal(10, 2)
  fornecedor       String
  numeroNotaFiscal String?
  total            Decimal  @db.Decimal(12, 2)
  criadoEm         DateTime @default(now())
  peca             Peca     @relation(fields: [pecaId], references: [id])

  @@map("entradas_pecas")
}

model MovimentacaoPeca {
  id               String             @id @default(uuid())
  pecaId           String
  dataMovimentacao DateTime
  lojaRequisitante String
  quantidade       Int
  numeroChamado    String?
  status           StatusMovimentacao @default(PENDENTE)
  criadoEm         DateTime           @default(now())
  peca             Peca               @relation(fields: [pecaId], references: [id])

  @@map("movimentacoes_pecas")
}

model SaidaPeca {
  id          String   @id @default(uuid())
  pecaId      String
  data        DateTime
  quantidade  Int      @default(1)
  destino     String
  nomeRetirou String
  empresa     String
  criadoEm    DateTime @default(now())
  peca        Peca     @relation(fields: [pecaId], references: [id])

  @@map("saidas_pecas")
}

model ChecklistEquipamento {
  id           String                     @id @default(uuid())
  semana       Int
  ano          Int
  regiao       String
  unidade      String
  criadoPorId  String
  observacoes  String?
  criadoEm     DateTime                   @default(now())
  atualizadoEm DateTime                   @updatedAt
  itens        ChecklistEquipamentoItem[]
  criadoPor    Usuario                    @relation(fields: [criadoPorId], references: [id])

  @@unique([semana, ano, unidade], name: "semana_ano_unidade")
  @@map("checklists_equipamento")
}

model ChecklistEquipamentoItem {
  id                 String               @id @default(uuid())
  checklistId        String
  tipoEquipamento    TipoEquipamento
  operacional        Boolean              @default(true)
  quantidade         Int                  @default(1)
  quantidadeQuebrada Int                  @default(0)
  numeroSerie        String?
  numeroChamado      String?
  descricaoProblema  String?
  valor              Decimal?             @db.Decimal(12, 2)
  checklist          ChecklistEquipamento @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_equipamento_itens")
}

model ChecklistCarrinho {
  id           String                  @id @default(uuid())
  semana       Int
  ano          Int
  regiao       String
  unidade      String
  criadoPorId  String
  observacoes  String?
  criadoEm     DateTime                @default(now())
  atualizadoEm DateTime                @updatedAt
  itens        ChecklistCarrinhoItem[]
  criadoPor    Usuario                 @relation(fields: [criadoPorId], references: [id])

  @@unique([semana, ano, unidade], name: "semana_ano_unidade")
  @@map("checklists_carrinho")
}

model ChecklistCarrinhoItem {
  id                String            @id @default(uuid())
  checklistId       String
  tipoCarrinho      TipoCarrinho
  total             Int               @default(0)
  quebrados         Int               @default(0)
  numeroChamado     String?
  descricaoProblema String?
  checklist         ChecklistCarrinho @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_carrinho_itens")
}

model FrotaCarrinho {
  id           String       @id @default(uuid())
  unidade      String
  tipoCarrinho TipoCarrinho
  total        Int          @default(0)
  atualizadoEm DateTime     @updatedAt

  @@unique([unidade, tipoCarrinho])
  @@map("frota_carrinhos")
}

enum Role {
  ADMINISTRADOR
  DIRETOR
  GERENTE
  COORDENADOR
  GESTOR
  TECNICO
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusTarefa {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum SegmentoChamado {
  ELETRICA
  EMPILHADEIRA
  REFRIGERACAO
  REFRIGERACAO_PÇS
  AR_CONDICIONADO
  SERRALHERIA
  CIVIL
  EQUIPAMENTOS
  SERVIÇOS_GERAIS
  GERADOR
  ELEVADOR
  PCI
  DIVERSOS
  ALUGUEL
}

enum StatusChamado {
  CHAMADO_ABERTO
  AGUARDANDO_APROVACAO
  AGUARDANDO_OM_ENTREGA
  FINALIZADO
  ALUGUEL_OUTROS
}

enum StatusMovimentacao {
  PENDENTE
  ENVIADO
  RECEBIDO
  CANCELADO
}

enum TipoEquipamento {
  EMPILHADEIRA_ELETRICA
  EMPILHADEIRA_COMBUSTAO
  EMPILHADEIRA_PATOLADA
  MAQUINA_MOER_CARNE
  SERRA_FITA
  EMBALADORA_VACUO
  FATIADORA
  FATIADORA_GRANDE
  ELEVADOR
  ILHASELF
  ESCADA_ROLANTE
}

enum TipoCarrinho {
  MARIA_GORDA
  SUPERCAR
  DOIS_ANDARES
  PRANCHA
  PRANCHA_PERECIVEIS
  CARRINHO_ABASTECIMENTO
  ESCADA
}
