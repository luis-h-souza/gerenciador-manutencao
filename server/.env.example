# ============================================================
# GERENCIADOR DE MANUTENÇÃO - Environment Variables Template
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA versione o seu arquivo .env real no Git.

# --- Aplicação ---
NODE_ENV=development
PORT=3001
APP_NAME="Gerenciador de Manutenção"

# --- Banco de Dados (PostgreSQL) ---
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://admin:admin123@localhost:5433/sgm_db?schema=public"

# --- JWT (Segurança dos Tokens) ---
# Use strings longas e aleatórias para produção
JWT_SECRET=mudar_para_uma_chave_secreta_longa_e_aleatoria_em_producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=mudar_para_uma_chave_de_refresh_longa_e_aleatoria
JWT_REFRESH_EXPIRES_IN=7d

# --- Sessions (Express Session) ---
SESSION_SECRET=mudar_para_uma_chave_de_sessao_segura
SESSION_MAX_AGE=86400000  # 24 horas em milisegundos

# --- Redis (para sessions e rate limiting distribuído) ---
REDIS_URL=redis://localhost:6379
# Para Redis com senha:
# REDIS_URL=redis://:senha_aqui@localhost:6379

# --- Rate Limiting (Proteção contra Brute Force) ---
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=100             # Máximo de requisições globais por janela
AUTH_RATE_LIMIT_MAX=10         # Máximo de tentativas de login por janela

# --- CORS (Segurança de Origem) ---
# URL onde o seu Frontend (Vite) está rodando
CORS_ORIGIN=http://localhost:3000

# --- Logs ---
LOG_LEVEL=info
LOG_DIR=./logs
